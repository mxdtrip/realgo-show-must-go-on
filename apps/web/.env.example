# Base URL of the Go API. Used by the web API client (app/_api).
# Copy to .env.local for local development.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Dev-only: set to 1 to open the cabinet UI without logging in (skips the auth
# guard). Useful for working on cabinet pages on mocks before the backend is up.
# Leave unset in production.
# NEXT_PUBLIC_AUTH_BYPASS=1
