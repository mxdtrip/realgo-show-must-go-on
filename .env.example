# Docker Compose local defaults.
# Copy to .env and replace AUTH_JWT_SECRET before starting the stack.

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=freeburger
DB_PORT=5432

REDIS_PORT=6379
REDIS_PASSWORD=

API_PORT=8080

AUTH_JWT_SECRET=replace-with-at-least-32-random-characters
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=720h
