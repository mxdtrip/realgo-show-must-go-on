# Docker Compose local defaults.
# Copy to .env and replace AUTH_JWT_SECRET before starting the stack.

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=freeburger
DB_PORT=5432

REDIS_PORT=6379
REDIS_PASSWORD=

API_PORT=8080

# Public site address used by the root Caddyfile for direct deployments.
# The default production domain is realgo.dev. The frp home stack uses
# Caddyfile.internal instead and does not read this value.
REALGO_SITE_ADDRESS=realgo.dev

AUTH_JWT_SECRET=replace-with-at-least-32-random-characters
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=720h

# Optional comma-separated CIDRs for reverse proxies whose X-Forwarded-For
# headers should be trusted by the API rate limiter.
TRUSTED_PROXY_CIDRS=

# Set this to the published Chrome extension origin, for example:
# chrome-extension://abcdefghijklmnopabcdefghijklmnop
REALGO_EXTENSION_ORIGIN=

# Base URL baked into the web app for API calls. Leave EMPTY in the tunnel setup:
# the frontend and API share the realgo.dev origin (Caddy routes /api/* to the
# api container), so relative URLs work and no CORS is needed.
NEXT_PUBLIC_API_BASE_URL=

# Reverse tunnel to the VPS edge (see deploy/vps/). Home is CGNAT'd and the
# provider blocks Cloudflare, so frpc dials OUT to a VPS running frps and exposes
# the local stack through it. FRP_VPS_HOST = the VPS public IP / hostname;
# FRP_TOKEN = shared auth token (must match the VPS .env). Required for frpc.
FRP_VPS_HOST=
FRP_TOKEN=
