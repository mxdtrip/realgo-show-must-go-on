# Docker Compose local defaults.
# Copy to .env and replace AUTH_JWT_SECRET before starting the stack.

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=freeburger
DB_PORT=5432

REDIS_PORT=6379
REDIS_PASSWORD=

API_PORT=8080

# Public site address used by the root Caddyfile for direct deployments.
# The default production domain is realgo.dev. The frp home stack uses
# Caddyfile.internal instead and does not read this value.
REALGO_SITE_ADDRESS=realgo.dev

AUTH_JWT_SECRET=replace-with-at-least-32-random-characters
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=720h

# Comma-separated CIDRs for reverse proxies whose X-Forwarded-For headers the
# API rate limiter trusts. Empty here means the docker-compose default (all
# private ranges) applies — correct for the compose stack, where the api is only
# reachable through the caddy container. Set explicitly only to narrow it.
TRUSTED_PROXY_CIDRS=

# Password for the seeded demo users (tester/pro/admin@example.test). The seed
# job runs on every deploy and resets these accounts. REQUIRED on any publicly
# reachable deployment: the fallback default is documented in DEMO.md and
# therefore public knowledge.
SEED_USERS_PASSWORD=

# API runtime environment: "local" keeps human-readable debug logs, anything
# else switches to JSON logs at info level. Set to "production" on servers.
APP_ENV=local

# Chrome extension origin pinned by apps/extension/manifest.key.
REALGO_EXTENSION_ORIGIN=chrome-extension://kclglopmphebagjjimjhdpnmoddmbgea

# Base URL baked into the web app for API calls. Leave EMPTY in the tunnel setup:
# the frontend and API share the realgo.dev origin (Caddy routes /api/* to the
# api container), so relative URLs work and no CORS is needed.
NEXT_PUBLIC_API_BASE_URL=

# Optional prod-demo reverse tunnel to the VPS edge (see deploy/vps/). Used only
# with `docker compose --profile prod-demo up ...`; regular dev up ignores it.
# FRP_VPS_HOST = the VPS public IP / hostname; FRP_TOKEN = shared auth token
# (must match the VPS .env).
FRP_VPS_HOST=
FRP_TOKEN=

# VLESS subscription URL for the vpngw gateway. Cloudflare (fronting Groq's
# API) blocks this network's address space at the bot-management layer
# regardless of API key/model; vpngw tunnels api's outbound public traffic
# through this subscription's foreign exit (port 443, looks like normal
# HTTPS) so Groq calls actually reach it. Required to start vpngw (and
# therefore api, which shares its network namespace).
VPN_SUB_URL=
