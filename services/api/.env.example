# Config path
CONFIG_PATH=./config.yaml

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=freeburger
DB_SSLMODE=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m

# HTTP Server
ADDRESS=localhost:8080

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth
AUTH_JWT_SECRET=replace-with-at-least-32-random-characters
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=720h

# AI card generation (optional: leave the key empty to disable generation).
# Get a personal free key at https://aistudio.google.com/apikey — do NOT share
# keys or commit them; prod uses the GEMINI_API_KEY GitHub Actions secret.
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
